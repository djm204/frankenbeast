{
  "name": "@franken/planner",
  "version": "0.4.18",
  "description": "MOD-04: Planning and Decomposition module for the Frankenbeast AI agent system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "dependencies": {
    "@franken/types": "0.12.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "license": "MIT",
  "keywords": [
    "frankenbeast",
    "planning",
    "decomposition",
    "agent"
  ]
}
