{
  "name": "@franken/governor",
  "version": "0.5.7",
  "description": "MOD-07: Human-in-the-Loop (HITL) & Governance for the Frankenbeast AI agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=true vitest run",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "frankenbeast",
    "hitl",
    "governance",
    "human-in-the-loop"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@franken/types": "0.7.4",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
