{
  "name": "@franken/governor",
  "version": "0.5.13",
  "description": "MOD-07: Human-in-the-Loop (HITL) & Governance for the Frankenbeast AI agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=true vitest run",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "frankenbeast",
    "hitl",
    "governance",
    "human-in-the-loop"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "dependencies": {
    "@franken/types": "0.8.2",
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
