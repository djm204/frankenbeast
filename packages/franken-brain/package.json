{
  "name": "@franken/brain",
  "version": "0.7.5",
  "description": "MOD-03: Memory Systems for the Frankenbeast AI agent",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "frankenbeast",
    "memory",
    "agent-memory",
    "sqlite"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@franken/types": "0.9.0",
    "better-sqlite3": "^12.11.1"
  },
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  }
}
