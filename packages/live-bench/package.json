{
  "name": "@franken/live-bench",
  "version": "0.2.5",
  "description": "Live Codex/Gemini CLI benchmark runner for Frankenbeast MCP suite A/B comparisons",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fbeast-live-bench": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "corpus",
    "fixtures"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "npm run build && FBEAST_LIVE_BENCH_E2E=1 vitest run tests/live",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "dependencies": {
    "@franken/observer": "0.7.15",
    "@franken/types": "0.8.2",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "license": "MIT"
}
