{
  "name": "@fbeast/live-bench",
  "version": "0.1.0",
  "description": "Live Codex/Gemini CLI benchmark runner for Frankenbeast MCP suite A/B comparisons",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fbeast-live-bench": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "corpus",
    "fixtures"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:live": "FBEAST_LIVE_BENCH_E2E=1 vitest run tests/live",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "dependencies": {
    "@frankenbeast/observer": "0.7.9",
    "better-sqlite3": "^12.6.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
