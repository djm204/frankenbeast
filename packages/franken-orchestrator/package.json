{
  "name": "@franken/orchestrator",
  "version": "0.40.0",
  "description": "The Beast Loop — orchestrator wiring all Frankenbeast modules into a unified agent pipeline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "frankenbeast": "./dist/cli/run.js",
    "franken": "./dist/cli/run.js",
    "frkn": "./dist/cli/run.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "chat-server": "npm run build && node dist/cli/run.js chat-server",
    "beasts-daemon": "npm run build && node dist/cli/run.js beasts-daemon",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=true vitest run",
    "test:e2e": "E2E=true vitest run",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "frankenbeast",
    "orchestrator",
    "agent",
    "beast-loop"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@franken/critique": "0.6.11",
    "@franken/governor": "0.5.9",
    "@franken/types": "0.7.6",
    "@franken/observer": "0.7.11",
    "@google/genai": "^1.46.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "@franken/planner": "0.4.9",
    "@franken/brain": "0.7.0",
    "hono": "^4.12.27",
    "openai": "^6.32.0",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
