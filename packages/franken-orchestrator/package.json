{
  "name": "@franken/orchestrator",
  "version": "0.59.0",
  "description": "The Beast Loop — orchestrator wiring all Frankenbeast modules into a unified agent pipeline",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "frankenbeast": "./dist/cli/run.js",
    "franken": "./dist/cli/run.js",
    "frkn": "./dist/cli/run.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "chat-server": "npm run build && node dist/cli/run.js chat-server",
    "beasts-daemon": "npm run build && node dist/cli/run.js beasts-daemon",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=true vitest run",
    "test:e2e": "E2E=true vitest run",
    "lint": "eslint src/ tests/ test/",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "keywords": [
    "frankenbeast",
    "orchestrator",
    "agent",
    "beast-loop"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@franken/critique": "0.11.1",
    "@franken/governor": "0.9.1",
    "@franken/types": "0.18.0",
    "@franken/observer": "0.12.1",
    "@google/genai": "^2.13.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "@franken/planner": "0.4.27",
    "@franken/brain": "0.18.0",
    "hono": "^4.12.31",
    "openai": "^6.48.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
