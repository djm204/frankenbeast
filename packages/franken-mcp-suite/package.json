{
  "name": "@franken/mcp-suite",
  "version": "0.2.12",
  "description": "MCP server suite exposing frankenbeast capabilities as Claude Code tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fbeast": "./dist/cli/main.js",
    "fbeast-mcp": "./dist/beast.js",
    "fbeast-hook": "./dist/cli/hook.js",
    "fbeast-memory": "./dist/servers/memory.js",
    "fbeast-planner": "./dist/servers/planner.js",
    "fbeast-critique": "./dist/servers/critique.js",
    "fbeast-firewall": "./dist/servers/firewall.js",
    "fbeast-observer": "./dist/servers/observer.js",
    "fbeast-governor": "./dist/servers/governor.js",
    "fbeast-skills": "./dist/servers/skills.js",
    "fbeast-proxy": "./dist/servers/proxy.js",
    "fbeast-init": "./dist/cli/init.js",
    "fbeast-uninstall": "./dist/cli/uninstall.js"
  },
  "files": [
    "dist",
    "instructions"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ \"src/**/*.test.ts\" \"src/**/*.integration.test.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:integration": "vitest run --reporter=verbose src/**/*.integration.test.ts",
    "test:watch": "vitest --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "dependencies": {
    "@franken/types": "0.10.1",
    "@franken/brain": "0.8.1",
    "@franken/critique": "0.8.1",
    "@franken/governor": "0.6.1",
    "@franken/observer": "0.7.18",
    "@franken/orchestrator": "0.44.2",
    "@franken/planner": "0.4.16",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "license": "MIT",
  "keywords": [
    "frankenbeast",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "agent-tools"
  ]
}
