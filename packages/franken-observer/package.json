{
  "name": "@franken/observer",
  "version": "0.7.16",
  "description": "MOD-05 – Observability and Evaluation for the Frankenbeast system",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION=true vitest run --reporter=verbose",
    "test:eval": "EVAL=true vitest run --reporter=verbose",
    "prepublishOnly": "npm --prefix ../.. run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@franken/types": "0.9.0",
    "better-sqlite3": "^12.11.1"
  },
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "license": "MIT",
  "keywords": [
    "frankenbeast",
    "observability",
    "evaluation",
    "tracing",
    "metrics"
  ]
}
