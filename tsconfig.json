{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "franken-brain": [
        "./packages/franken-brain/src/index.ts"
      ],
      "franken-planner": [
        "./packages/franken-planner/src/index.ts"
      ],
      "@frankenbeast/observer": [
        "./packages/franken-observer/src/index.ts"
      ],
      "@franken/critique": [
        "./packages/franken-critique/src/index.ts"
      ],
      "@franken/governor": [
        "./packages/franken-governor/src/index.ts"
      ],
      "@franken/types": [
        "./packages/franken-types/src/index.ts"
      ],
      "franken-orchestrator": [
        "./packages/franken-orchestrator/src/index.ts"
      ]
    }
  },
  "include": [],
  "exclude": [
    "node_modules"
  ]
}
