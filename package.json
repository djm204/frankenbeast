{
  "name": "frankenbeast",
  "version": "0.42.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Deterministic guardrails framework for AI agents",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "audit:security": "node scripts/check-package-manager.mjs && npm audit --audit-level=moderate",
    "check:package-manager": "node scripts/check-package-manager.mjs",
    "lint:any": "node scripts/audit-explicit-any.mjs",
    "lint:security": "node scripts/check-plain-http.mjs && node scripts/check-hardcoded-secrets.mjs",
    "test": "turbo run test",
    "test:root": "vitest run",
    "test:root:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "acorn": "^8.17.0",
    "better-sqlite3": "^12.6.2",
    "sharp": "^0.34.5",
    "turbo": "^2.10.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@11.5.1",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0 <26"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "hono": "^4.12.27",
    "protobufjs": "^7.6.5",
    "vite": "^8.1.3",
    "ws": "^8.21.0"
  }
}
