{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["FRANKENBEAST_SEED"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/scripts/vitest-*.ts",
        "$TURBO_ROOT$/packages/*/src/**"
      ],
      "env": ["INTEGRATION", "E2E", "EVAL", "DOCKER_BUILD"]
    },
    "test:ci": {
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
